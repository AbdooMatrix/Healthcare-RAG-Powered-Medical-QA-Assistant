# ═══════════════════════════════════════════════════════════════════════════════
# Healthcare RAG-Powered Medical Q&A Assistant — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
healthcare_rag.egg-info/

# ─── Virtual Environments ───────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Environment Variables / Secrets ────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Model Weights (too large for GitHub — reproducible from notebooks) ────
models/classifier/distilbert_classifier/*.bin
models/classifier/distilbert_classifier/*.safetensors
models/classifier/distilbert_classifier/model.safetensors
models/classifier/distilbert_classifier/pytorch_model.bin
models/classifier/distilbert_classifier/tokenizer.json
models/classifier/distilbert_classifier/vocab.txt
models/classifier/checkpoints/

# ─── Data Files (reproducible from notebooks) ──────────────────────────────
data/raw/*.csv
data/processed/*.csv

# ─── FAISS Index & Embeddings (reproducible from notebook 05) ──────────────
data/embeddings/faiss_index/*.faiss
data/embeddings/faiss_index/*.pkl
data/embeddings/faiss_index/*.csv

# ─── Jupyter Notebook ──────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── IDE / Editor ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ─── OS Files ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Logs & Temp ───────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig

# ─── MLflow (local tracking — can be large) ────────────────────────────────
mlruns/
mlartifacts/

# ─── Docker ────────────────────────────────────────────────────────────────
docker/.env

# ─── Distribution / Packaging ──────────────────────────────────────────────
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ─── Testing ───────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ─── HuggingFace Cache (large model downloads) ────────────────────────────
.cache/
~/.cache/huggingface/