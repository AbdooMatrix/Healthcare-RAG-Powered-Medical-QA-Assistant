# ═══════════════════════════════════════════════════════════════════════════════
# Healthcare RAG-Powered Medical Q&A Assistant — .gitignore (PRODUCTION READY)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
healthcare_rag.egg-info/

# ─── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Environment Variables / Secrets ─────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Model Weights (ALL classifiers - SAFE FOR RAG PROJECTS) ─────────────────
models/classifier/**/
!models/classifier/**/config.json
!models/classifier/**/tokenizer_config.json
!models/classifier/**/special_tokens_map.json
!models/classifier/**/README.md

# ─── Checkpoints ──────────────────────────────────────────────────────────────
models/**/checkpoints/

# ─── Data Files (reproducible / externalized) ─────────────────────────────────
data/raw/*.csv
data/processed/*.csv

# ─── FAISS / Embeddings (rebuildable artifacts) ───────────────────────────────
data/embeddings/faiss_index/
*.faiss
*.pkl

# ─── Jupyter Notebook ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Logs & Temp Files ────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig

# ─── MLflow (local tracking) ──────────────────────────────────────────────────
mlruns/
mlartifacts/

# ─── Docker ───────────────────────────────────────────────────────────────────
docker/.env

# ─── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ─── HuggingFace / Transformers Cache ─────────────────────────────────────────
.cache/
huggingface/
**/.cache/