# ────────────────────────────────────────────────────
# Healthcare RAG — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# ────────────────────────────────────────────────────

WEBSITE_PORT=8000

# Groq API key (optional — enables llama-3.1-8b-instant; falls back to flan-t5-base)
# Get yours at: https://console.groq.com
GROQ_API_KEY=

# HuggingFace token — needed to download the DistilBERT classifier in Docker / Azure
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure App Service URL — fill in after M3 deployment
AZURE_APP_URL=https://healthcare-rag-app.azurewebsites.net
