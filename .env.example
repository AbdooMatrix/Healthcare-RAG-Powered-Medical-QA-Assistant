# ──────────────────────────────────────────────────────────────────────────────
# Healthcare RAG — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit it.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Security ──────────────────────────────────────────────────────────────
# Optional: leave empty to disable auth in local development
API_KEY=

# ── Groq LLM API ─────────────────────────────────────────────────────────────
# Required for LLM generation. Get your key at: https://console.groq.com
# Model: meta-llama/llama-4-scout-17b-16e-instruct (Groq-hosted)
# Falls back to local google/flan-t5-base if not set.
# You can provide multiple keys separated by commas — they will be rotated
# automatically on rate limits (HTTP 429). Example:
#   GROQ_API_KEY="key1,key2,key3,key4"
GROQ_API_KEY=

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required to download BioBERT classifier + FAISS data from HuggingFace Hub.
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Deployment info (shown on Streamlit dashboard) ───────────────────────────
DEPLOY_ENV=local
DEPLOY_DATE=

# ── Azure App Service ─────────────────────────────────────────────────────────
# Filled automatically by deploy.sh after deployment.
AZURE_APP_URL=
WEBSITES_PORT=8000

# ── Local Docker port ─────────────────────────────────────────────────────────
# Port for local Docker runs. Azure uses WEBSITES_PORT above.
WEBSITE_PORT=8000
