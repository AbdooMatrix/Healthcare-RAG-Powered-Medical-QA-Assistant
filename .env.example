# ────────────────────────────────────────────────────
# Healthcare RAG — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# ────────────────────────────────────────────────────

WEBSITE_PORT=8000

# API key for /query endpoint (leave empty to disable auth in dev)
API_KEY=

# Groq API key (optional — enables meta-llama/llama-4-scout-17b-16e-instruct; falls back to flan-t5-base)
# Get yours at: https://console.groq.com
GROQ_API_KEY=

# HuggingFace token — needed to download the BioBERT classifier in Docker / Azure
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deployment info (shown on Streamlit dashboard)
DEPLOY_ENV=local
DEPLOY_DATE=

# Azure App Service URL — fill in after M3 deployment
AZURE_APP_URL=https://healthcare-rag-app.azurewebsites.net
