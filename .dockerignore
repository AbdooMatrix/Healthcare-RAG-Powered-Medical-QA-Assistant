# ── Data & models ───────────────────────────────────────────────
# Downloaded at container startup via download.py
data/
models/**/*.bin
models/**/*.safetensors
models/**/training_args.bin
models/**/optimizer.pt
models/**/scheduler.pt

# ── Source code NOT shipped ─────────────────────────────────────
# Azure deploy scripts — not part of the image
azure/
# Test files — not needed in production
tests/
# Documentation & notebooks
docs/
notebooks/
reports/
# MLOps runtime artifacts
mlruns/
mlartifacts/
LogFiles/

# ── Docker build files (keep only entrypoint scripts) ────────────
docker/*
!docker/entrypoint.sh
!docker/entrypoint-dashboard.sh
!docker/nginx-dashboard.conf

